{
  "name": "punto-de-venta-client",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://alejandroperezitsur.github.io/Punto-de-Venta/",
  "description": "Frontend POS con React y Vite",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chaos": "vitest run tests/chaos",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && npx gh-pages -d dist -b gh-pages --dotfiles"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "idb": "^8.0.3",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.561.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fake-indexeddb": "^6.0.0",
    "gh-pages": "^5.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.1.0",
    "workbox-window": "^7.4.0"
  }
}
